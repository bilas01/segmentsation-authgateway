# ── Base de données ───────────────────────────────────────────────
POSTGRES_DB=segstation_auth
POSTGRES_USER=segstation
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ── Secrets applicatifs (générer avec: openssl rand -hex 32) ─────
JWT_SECRET=CHANGE_ME_jwt_secret_32_chars_minimum
SESSION_SECRET=CHANGE_ME_session_secret_32_chars_minimum

# ── Compte admin initial ──────────────────────────────────────────
ADMIN_EMAIL=admin@segstation.org
ADMIN_PASSWORD=CHANGE_ME_admin_password

# ── Domaine ───────────────────────────────────────────────────────
APP_DOMAIN=segstation.org

# ── Port exposé vers le reverse proxy existant ────────────────────
# L'auth-gateway écoute sur 127.0.0.1:GATEWAY_PORT uniquement.
# Ton reverse proxy (Nginx/Caddy/HAProxy) redirige le trafic HTTPS
# de segstation.org et admin.segstation.org vers ce port.
GATEWAY_PORT=3000

# ── Mailer (Resend, Postmark, SMTP…) ─────────────────────────────
MAILER_HOST=smtp.resend.com
MAILER_PORT=587
MAILER_USER=resend
MAILER_PASS=re_XXXXXXXXXXXXX
MAILER_FROM=noreply@segstation.org
